# Shell scripts and the compliance-hooks extension must be LF so they run under
# bash/Node on Linux/macOS/WSL even when authored on Windows.
*.sh       text eol=lf
*.example  text eol=lf
*.mjs      text eol=lf
.template-source text eol=lf
.githooks/pre-push text eol=lf

# Integrity-addressed redistribution text must have checkout-stable bytes on every platform.
third_party/pascual-roms/*.md text eol=lf
third_party/pascual-roms/*.txt text eol=lf
third_party/pascual-roms/*.json text eol=lf
third_party/pascual-roms/COPYING text eol=lf
third_party/pascual-roms/COPYING.LESSER text eol=lf
