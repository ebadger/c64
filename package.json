{
  "name": "c64",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic browser/Node source-to-artifact pipeline for Commodore 64 software (assembler, PRG, D64).",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test tests/",
    "test:pipeline": "node --test tests/",
    "test:web": "node --test tests/web/",
    "test:wasm": "node --test tests/wasm/",
    "test:e2e": "node --test tests/e2e/",
    "build:native": "sh scripts/build/build-native.sh",
    "build:wasm": "sh scripts/build/build-wasm.sh",
    "example": "node examples/build-example.mjs",
    "gallery": "node web/client/tools/build-gallery.mjs",
    "serve": "node scripts/dev/serve.mjs"
  },
  "exports": {
    ".": "./src/index.js",
    "./emulator": "./web/emulator/c64.mjs"
  },
  "files": [
    "src/",
    "web/emulator/"
  ],
  "license": "SEE LICENSE IN CONTRIBUTING.md"
}
