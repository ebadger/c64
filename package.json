{
  "name": "c64",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic browser/Node source-to-artifact pipeline for Commodore 64 software (assembler, PRG, D64).",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node scripts/dev/run-node-tests.mjs tests",
    "test:pipeline": "node scripts/dev/run-node-tests.mjs tests",
    "test:web": "node scripts/dev/run-node-tests.mjs tests/web",
    "test:dist": "node scripts/dev/run-node-tests.mjs tests/dist",
    "test:wasm": "node scripts/dev/run-node-tests.mjs tests/wasm",
    "test:e2e": "node scripts/dev/run-node-tests.mjs tests/e2e",
    "test:interop": "node scripts/dev/run-node-tests.mjs tests/interop",
    "build:native": "sh scripts/build/build-native.sh",
    "build:kernal-rom": "node scripts/build/build-kernal-rom.mjs",
    "build:drive-rom": "node scripts/build/build-drive-rom.mjs",
    "build:wasm": "sh scripts/build/build-wasm.sh",
    "build:dist": "node scripts/build/build-dist.mjs",
    "example": "node examples/build-example.mjs",
    "gallery": "node web/client/tools/build-gallery.mjs",
    "serve": "node scripts/dev/serve.mjs"
  },
  "exports": {
    ".": "./src/index.js",
    "./emulator": "./web/emulator/c64.mjs"
  },
  "files": [
    "src/",
    "web/emulator/"
  ],
  "license": "SEE LICENSE IN CONTRIBUTING.md"
}
