diff --git a/src/kernal.s b/src/kernal.s
index 855776b..e371ec1 100644
--- a/src/kernal.s
+++ b/src/kernal.s
@@ -27,6 +27,7 @@ KBITCNT = $00A6         ; contador de bits
 KSERHI  = $00A7         ; byte alto del timeout RFD (espera de oyente)
 KLDPTR  = $00AE         ; puntero destino/fin de LOAD-SAVE (lo/hi)
 KLDTMP  = $00AC         ; byte bajo temporal de la direccion de carga
+KLDTMPHI = $00AD        ; byte alto original de la direccion de carga
 KSAVPTR = $00C1         ; puntero de trabajo de SAVE (lo/hi)
 KFNLEN  = $00B7         ; longitud del nombre de fichero
 KLA     = $00B8         ; fichero logico actual
@@ -48,4 +49,49 @@ KMATRIX = $02A0         ; estado anterior de la matriz (8 bytes)
 SCREEN  = $0400
 COLOR   = $D800
-
+
+.org $E179              ; hueco libre antes de la continuacion del KERNAL
+KLOADHI:
+        jsr KACPTR
+        sta KLDTMPHI
+        rts
+
+BLOADBOUND:
+        lda KSA
+        beq @set
+        lda KLDTMP
+        cmp TXTTAB
+        bne @done
+        lda KLDTMPHI
+        cmp TXTTAB+1
+        bne @done
+@set:   stx VARTAB
+@done:  rts
+
+KCUROFF_IMPL:
+        pha
+        lda KBLON
+        beq @no
+        sei
+        tya
+        pha
+        ldy KCOL
+        lda (KPNT),Y
+        eor #$80
+        sta (KPNT),Y
+        lda KPNT
+        sta KCPTR
+        lda KPNT+1
+        clc
+        adc #$D4
+        sta KCPTR+1
+        lda KGDCOL
+        sta (KCPTR),Y
+        lda #$00
+        sta KBLON
+        pla
+        tay
+        cli
+@no:    pla
+        rts
+
 .org $E200              ; tras la continuacion del BASIC
@@ -108,11 +136,12 @@ KIOINIT:
 ; RAMTAS ($FF87): limpiar areas de trabajo y reloj
 ; ------------------------------------------------------------
 KRAMTAS:
         lda #$00
-        tax
-@rt1:   sta $0002,X     ; pagina cero (sin tocar el puerto 6510)
+        ldx #$02
+@rt1:   sta $00,X       ; pagina cero $02-$FF; preservar DDR/puerto 6510
         inx
         bne @rt1
+        ldx #$00
 @rt2:   sta $0200,X     ; pagina 2 (bufers)
         inx
         bne @rt2
@@ -557,8 +586,8 @@ KSCNKEY:
         inx
         cpx #$08
         bne @col
-        lda #$00
-        sta $DC00       ; todas las filas activas (para STOP)
+        lda #$7F
+        sta $DC00       ; fila STOP activa; joystick 2 liberado en reposo
         ; --- estado de shift: LSHIFT col1/bit7, RSHIFT col6/bit4 ---
         lda #$00
         sta KSHIFT
@@ -1080,32 +1109,10 @@ KCHRIN:
         jmp @servir
-
+
 ; apagar el cursor si esta invertido (auxiliar del editor)
-KCUROFF:
-        pha
-        lda KBLON
-        beq @no
-        sei
-        tya
-        pha
-        ldy KCOL
-        lda (KPNT),Y
-        eor #$80
-        sta (KPNT),Y
-        lda KPNT        ; restaurar el color guardado bajo el cursor
-        sta KCPTR
-        lda KPNT+1
-        clc
-        adc #$D4
-        sta KCPTR+1
-        lda KGDCOL
-        sta (KCPTR),Y
-        lda #$00
-        sta KBLON
-        pla
-        tay
-        cli
-@no:    pla
-        rts
+KCUROFF: jmp KCUROFF_IMPL
+        .org $EA31
+        jmp KIRQ        ; continuacion compatible para IRQ personalizados
+        .org $EA56
-
+
 KLINE   = $033C         ; bufer de linea leida (cassette buffer, sin cinta)
 KLLEN   = $02EA
@@ -1156,10 +1166,9 @@ KSTOPRAW:
         lda $DC01
         and #$80        ; bit 7 = RUN/STOP
         tax             ; resultado a X (sobrevive a un IRQ)
-        lda #$00
-        sta $DC00
+        lda #$7F
+        sta $DC00       ; mantener joystick 2 liberado tras la lectura
         plp
         txa             ; A = resultado, fija Z
         rts             ; Z=1 si pulsada
-
 ; ------------------------------------------------------------
@@ -2074,10 +2093,9 @@ BLOAD:  jsr BPARSE
         jsr $FFD5       ; LOAD via vector ILOAD (interceptable)
         bcc @lok
         jmp KIOERR      ; error de E/S
-@lok:   ; si SA=0 (programa BASIC), fijar VARTAB=fin y reenlazar
-        lda KSA
-        bne @lret
-        stx VARTAB      ; X/Y = fin+1 devuelto por KLOAD
+@lok:   jsr BLOADBOUND ; SA=0, o SA<>0 con direccion de fichero=TXTTAB
+        bne @lret
+        nop             ; conserva la direccion de la siguiente instruccion
         sty VARTAB+1
         ; Guarda: si la carga relocalizada dejo menos de 2 bytes (longitud =
         ; VARTAB-TXTTAB < 2), el area de programa puede no tener un terminador
@@ -2232,7 +2250,7 @@ KLOAD:  sta KVERCK
 @addr:  ; leer la direccion de carga del fichero (2 bytes)
         jsr KACPTR
         sta KLDTMP
-        jsr KACPTR          ; A = byte alto
+        jsr KLOADHI         ; A = byte alto; conservar la direccion original
         ldx KSA
         beq @loop           ; SA=0 -> relocalizar a KLDPTR (X/Y de entrada)
         sta KLDPTR+1        ; SA<>0 -> usar la direccion del fichero
