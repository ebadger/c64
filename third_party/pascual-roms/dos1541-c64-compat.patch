+; ----------------------------------------------------------------------------
+;  c64 compat: comodines de directorio y acceso directo por bloque (U1).
+;  Reproducen, en fuente, las correcciones de compatibilidad que el constructor
+;  de ROM aplica sobre el binario DOS-1541 empaquetado (dos1541-upstream.rom).
+; ----------------------------------------------------------------------------
+
+;  dir_name_match: compara NAME_BUF (patron, con '*'/'?') contra la entrada de
+;  directorio en DIR_BUF,Y. Entra con X=0 e Y=offset del nombre en DIR_BUF. '*'
+;  casa con el resto; '?' casa con un caracter cualquiera. Devuelve carry set si
+;  casa (SEC) y carry clear si no (CLC). Consume X e Y.
+dir_name_match:
+@nm:
+    lda NAME_BUF,x
+    cmp #'*'
+    beq @match                  ; '*' casa con lo que quede
+    cmp #'?'
+    beq @skip                   ; '?' casa con un caracter cualquiera
+    cmp DIR_BUF,y
+    bne @nomatch
+@skip:
+    iny
+    inx
+    cpx #16
+    bne @nm
+@match:
+    sec
+    rts
+@nomatch:
+    clc
+    rts
+
+;  u1_parse_dec: lee un numero decimal de DATA_BUF a partir de X, saltando los
+;  separadores no numericos, hasta data_idx. Devuelve A = valor con carry clear;
+;  carry set si no hay ningun digito antes de data_idx. Avanza X tras el numero.
+u1_parse_dec:
+@skip:
+    cpx data_idx
+    bcs @err                    ; fin del comando sin digito
+    lda DATA_BUF,x
+    cmp #'0'
+    bcc @notdig
+    cmp #':'                    ; '9' + 1
+    bcc @parse
+@notdig:
+    inx
+    bne @skip                   ; siempre (X < 256)
+@err:
+    sec
+    rts
+@parse:
+    lda #$00
+    sta dec_acc
+@ploop:
+    cpx data_idx
+    bcs @done
+    lda DATA_BUF,x
+    cmp #'0'
+    bcc @done
+    cmp #':'
+    bcs @done
+    sec
+    sbc #'0'
+    sta dec_digit
+    lda dec_acc
+    asl a
+    sta dec_tmp                 ; acc*2
+    asl a
+    asl a                       ; acc*8
+    clc
+    adc dec_tmp                 ; acc*10
+    clc
+    adc dec_digit
+    sta dec_acc
+    inx
+    bne @ploop
+@done:
+    lda dec_acc
+    clc
+    rts
+
+;  iec_u1_exec: interpreta "U1 canal unidad pista sector" acumulado en DATA_BUF
+;  (data_idx bytes), lee el sector en DATA_DEC_BUF+1 y marca el buffer de acceso
+;  directo como listo. Fija err_code (0 ok, 20 error de lectura, 30 sintaxis) y
+;  construye la cadena de estado en STATUS_BUF (tail-call a err_build_status).
+iec_u1_exec:
+    lda #$00
+    sta direct_ready
+    sta err_track
+    sta err_sector
+    lda DATA_BUF+0
+    cmp #'U'
+    bne @syntax
+    lda DATA_BUF+1
+    cmp #'1'
+    bne @syntax
+    ldx #2
+    jsr u1_parse_dec            ; canal
+    bcs @syntax
+    sta direct_chan
+    jsr u1_parse_dec            ; unidad (debe ser 0)
+    bcs @syntax
+    cmp #$00
+    bne @syntax
+    jsr u1_parse_dec            ; pista
+    bcs @syntax
+    sta want_track
+    sta err_track
+    jsr u1_parse_dec            ; sector
+    bcs @syntax
+    sta want_sector
+    sta err_sector
+    jsr disk_read_sector_hw     ; -> DATA_DEC_BUF+1, fsec_error
+    lda fsec_error
+    bne @readerr
+    lda #$00
+    sta DATA_DEC_BUF            ; byte de framing del canal de acceso directo
+    lda #$FF
+    sta direct_ready
+    lda #$00                    ; 00 = OK
+    sta err_code
+    jmp @build
+@syntax:
+    lda #$1E                    ; 30 = SYNTAX ERROR
+    sta err_code
+    jmp @build
+@readerr:
+    lda #$14                    ; 20 = READ ERROR
+    sta err_code
+@build:
+    jmp err_build_status        ; construye STATUS_BUF y retorna (rts)
+
 ; ----------------------------------------------------------------------------
 irq_brk:
     rti
